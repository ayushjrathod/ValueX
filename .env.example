# =============================================================================
# ValueX Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values you need.
# Never commit your .env file.

# --- LLM (required) ---
# Used by the intent classifier and the Portfolio Health agent.
OPENAI_API_KEY=sk-...

# Use gpt-4o-mini during development to keep costs down.
# Evaluation runs against gpt-4.1.
OPENAI_MODEL=gpt-4o-mini

# --- Application ---
APP_ENV=development              # development | production | test
API_PORT=8000


# Pipeline budgets
PIPELINE_TIMEOUT_S=12
E2E_WARN_THRESHOLD_S=6
COST_BUDGET_USD=0.05

# Classifier tuning
CLASSIFIER_TEMPERATURE=0.1

# Portfolio agent tuning
PORTFOLIO_MAX_TOOL_ROUNDS=5
PORTFOLIO_TOOL_TEMPERATURE=0.2
PORTFOLIO_OBSERVATION_TEMPERATURE=0.4
PORTFOLIO_RECENT_HISTORY_TURNS=4

# Session memory
SESSION_MAX_TURNS=10
SESSION_TTL_SECONDS=3600

# Safety and market data
SAFETY_BLOCK_THRESHOLD=0.58
MARKET_DATA_MAX_WORKERS=10
